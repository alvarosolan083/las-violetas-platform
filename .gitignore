# -------------------------------------
# Root-level gitignore for monorepo
# -------------------------------------

# Node
node_modules/
**/node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
**/dist/
build/
**/build/
coverage/
**/coverage/

# Env files
.env
*.env
**/*.env

# Prisma generated files
**/.prisma/

# System / IDE
.DS_Store
.vscode/
.idea/
*.swp

# Logs
logs
*.log

# Uploads
uploads/
**/uploads/