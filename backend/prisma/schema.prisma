generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COMITE
  RESIDENTE
  CONSERJE
}

enum CondoRole {
  ADMINISTRADOR
  COMITE
  COPROPIETARIO
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Condominium {
  id          String   @id @default(cuid())
  name        String
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships   CondoMembership[]
  tickets       Ticket[]
  announcements Announcement[]
  units         Unit[]
}

model CondoMembership {
  id            String     @id @default(cuid())
  condominiumId String
  userId        String
  role          CondoRole
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  condominium   Condominium @relation(fields: [condominiumId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([condominiumId, userId])
  @@index([userId])
  @@index([condominiumId])
}

model Unit {
  id            String   @id @default(cuid())
  condominiumId String
  code          String   // ej: "T1-1204" o "1204"
  floor         Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  condominium   Condominium @relation(fields: [condominiumId], references: [id])

  @@unique([condominiumId, code])
  @@index([condominiumId])
}

model Ticket {
  id            String         @id @default(cuid())
  condominiumId String
  createdById   String
  title         String
  description   String
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(MEDIUM)
  category      String?        // "Portón", "Piscina", "Filtración", etc
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id])
  createdBy   User        @relation(fields: [createdById], references: [id])

  comments    TicketComment[]
  attachments TicketAttachment[]

  @@index([condominiumId, status])
  @@index([createdById])
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  message   String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
}

model TicketAttachment {
  id        String   @id @default(cuid())
  ticketId  String
  url       String
  filename  String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
}

model Announcement {
  id            String   @id @default(cuid())
  condominiumId String
  createdById   String
  title         String
  body          String
  createdAt     DateTime @default(now())

  condominium Condominium @relation(fields: [condominiumId], references: [id])
  createdBy   User        @relation(fields: [createdById], references: [id])

  @@index([condominiumId])
}

model Department {
  id        String   @id @default(cuid())
  tower     String?
  number    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(RESIDENTE)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  memberships    CondoMembership[]
  tickets        Ticket[]
  ticketComments TicketComment[]
  announcements  Announcement[]

  @@index([departmentId])
}
